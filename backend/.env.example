# Backend deployment env
APP_MODE=cloud
AUTH_REQUIRED=1
CLOUD_ONLY_MODE=1
LOGIN_ONLY_MODE=1
ALLOW_SELF_REGISTER=0
JWT_SECRET=replace-with-long-random-secret

# Network binding
HOST=0.0.0.0
PORT=5000

# Primary database (required for cloud and Vercel)
DATABASE_URL=postgresql://postgres:password@host:5432/database

# Optional local SQLite path for offline mode only
BILLING_DB_PATH=./billing.db
BILLING_BILLS_DIR=./bills

# Optional: force Postgres mode outside cloud/vercel environments
FORCE_POSTGRES=0

# Optional bootstrap admin account
DEFAULT_ADMIN_USERNAME=admin
# Set one of these for first login. Prefer password hash in production.
DEFAULT_ADMIN_PASSWORD_HASH=
DEFAULT_ADMIN_PASSWORD=Admin@123
