# Backend deployment env
APP_MODE=cloud
AUTH_REQUIRED=1
CLOUD_ONLY_MODE=1
LOGIN_ONLY_MODE=1
ALLOW_SELF_REGISTER=0
JWT_SECRET=replace-with-long-random-secret

# Network binding
HOST=0.0.0.0
PORT=5000

# Persistent data paths
BILLING_DB_PATH=./billing.db
BILLING_BILLS_DIR=./bills

# Optional bootstrap admin account
DEFAULT_ADMIN_USERNAME=admin
# Set one of these for first login. Prefer password hash in production.
DEFAULT_ADMIN_PASSWORD_HASH=
DEFAULT_ADMIN_PASSWORD=Admin@123
