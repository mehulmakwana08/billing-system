{
  "name": "arvind-billing-system",
  "version": "1.0.0",
  "description": "GST Billing System for Arvind Plastic Industries",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.arvind.billing",
    "productName": "Arvind Billing System",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "billing",
    "gst",
    "invoice",
    "india"
  ],
  "author": "Arvind Plastic Industries",
  "license": "MIT",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.2",
    "@supabase/supabase-js": "^2.100.1",
    "bootstrap": "^5.3.3",
    "chart.js": "^4.4.0",
    "electron-log": "^5.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
